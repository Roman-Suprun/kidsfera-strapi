{
    "kind": "collectionType",
    "collectionName": "feedbacks",
    "info": {
        "singularName": "feedback",
        "pluralName": "feedbacks",
        "displayName": "Feedback"
    },
    "options": {
        "draftAndPublish": true
    },
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "minLength": 2,
            "maxLength": 80
        },
        "content": {
            "type": "richtext",
            "required": true
        },
        "rating": {
            "type": "integer",
            "required": true,
            "default": 5,
            "min": 1,
            "max": 5
        },
        "product": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::product.product"
        },
        "project": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::project.project"
        }
    }
}
